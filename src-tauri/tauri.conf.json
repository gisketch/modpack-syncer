{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gisketch_s_modpack_syncer",
  "version": "1.0.5",
  "identifier": "dev.gisketch.s-modpack-syncer",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "gisketch_s_modpack_syncer",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDczODQwN0FENDBEREQzNTMKUldSVDA5MUFyUWVFY3hCeEM2bEtZZ3g4R1UyZjRKcXBjYWlpQ281Zi84OVZwNlpYN0tKUW52ZW4K",
      "endpoints": [
        "https://github.com/gisketch/modpack-syncer/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
